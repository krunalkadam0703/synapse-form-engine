{
  "name": "synapse-form-engine",
  "version": "1.0.0",
  "description": "Reactive headless form engine for React. Model-driven logic, automated dependency indexing, and surgical re-rendering for high-concurrency enterprise modules.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "vitest"
  },
  "homepage": "https://github.com/krunalkadam0703/synapse-form-engine#readme",
  "bugs": {
    "url": "https://github.com/krunalkadam0703/synapse-form-engine/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krunalkadam0703/synapse-form-engine.git"
  },
  "license": "ISC",
  "author": "krunal kadam",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.0.0",
    "eventemitter3": "^5.0.1",
    "expr-eval": "^2.0.2"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-hook-form": ">=7",
    "zod": ">=3"
  }
}